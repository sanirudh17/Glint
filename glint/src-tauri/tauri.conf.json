{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glint",
  "version": "0.1.1",
  "identifier": "com.glint.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "trayIcon": { "iconPath": "icons/icon.png", "tooltip": "Glint" },
    "windows": [
      {
        "title": "Glint",
        "label": "main",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$VIDEO/Glint/**", "$APPLOCALDATA/thumbs/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/ffmpeg", "binaries/ffprobe"],
    "resources": {
      "binaries/tesseract": "tesseract"
    }
  }
}
