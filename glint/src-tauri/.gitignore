# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Bundled ffmpeg/ffprobe sidecars (~100MB each) — copied per machine, never committed.
# Required at runtime; see PHASE-8/9 acceptance docs for the install step.
/binaries/ffmpeg-*
/binaries/ffprobe-*
# Bundled Tesseract OCR runtime (~160MB) — copied per machine, never committed.
# Glint auto-detects a winget-installed Tesseract if this folder is absent; see
# PHASE-10-OCR-ACCEPTANCE.md / scripts/fetch-tesseract.ps1.
/binaries/tesseract/
